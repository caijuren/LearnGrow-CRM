.container {
  padding-bottom: 60rpx;
}

.event-hero {
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 100%);
  margin: -24rpx -24rpx 24rpx;
  padding: 60rpx 40rpx 48rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.hero-title {
  line-height: 1.4;
}

.hero-badge {
  background: rgba(255, 255, 255, 0.2);
  color: white;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.reward-card {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border: none;
}

.checked-status {
  text-align: center;
  padding: 40rpx;
}

.check-icon {
  width: 120rpx;
  height: 120rpx;
  background: #dcfce7;
  color: #16a34a;
  border-radius: 50%;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.note-text {
  background: #f8fafc;
  padding: 20rpx;
  border-radius: 12rpx;
  color: #475569;
  text-align: left;
}

.checkin-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 12rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.label {
  font-size: 28rpx;
  color: #475569;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #f1f5f9;
}

.upload-area {
  width: 200rpx;
  height: 200rpx;
  background: #f8fafc;
  border: 2rpx dashed #e2e8f0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.streak-info {
  justify-content: space-around;
  padding: 24rpx 0;
  background: #fef2f2;
  border-radius: 16rpx;
}

.streak-item {
  text-align: center;
}

.streak-num {
  font-size: 48rpx;
}

.streak-label {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-weekday {
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
  padding: 12rpx 0;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  border-radius: 10rpx;
  color: #64748b;
}

.calendar-day.checked {
  background: linear-gradient(135deg, #f43f5e, #ec4899);
  color: white;
  font-weight: 600;
}

.calendar-day.today {
  border: 2rpx solid #f43f5e;
}

.calendar-day.today.checked {
  border: none;
}

.calendar-day.disabled {
  color: #e2e8f0;
}

.checkin-card {
  border: 2rpx solid #fecdd3;
  background: linear-gradient(180deg, #fff1f2 0%, #ffffff 30%);
}

.quick-photo {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 20rpx;
  margin-bottom: 8rpx;
}

.quick-photo-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.quick-photo-text {
  flex: 1;
}

.quick-photo-arrow {
  font-size: 40rpx;
  color: #92400e;
  font-weight: bold;
}

.btn-large {
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  border-radius: 48rpx;
}
