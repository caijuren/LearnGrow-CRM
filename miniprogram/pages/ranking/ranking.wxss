.container {
  padding-bottom: 60rpx;
}

.ranking-header {
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 60%, #f472b6 100%);
  margin: -32rpx -28rpx 0;
  padding: 80rpx 40rpx 140rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.ranking-header::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -60rpx;
  width: 280rpx;
  height: 280rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.ranking-header::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: 10%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}

.ranking-header .text-xl {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
}

.podium {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 20rpx;
  margin: -80rpx 0 32rpx;
  padding: 0 4rpx;
  position: relative;
  z-index: 10;
}

.podium-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: white;
  border-radius: 28rpx;
  padding: 28rpx 12rpx 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.podium-item.first {
  transform: translateY(-20rpx) scale(1.05);
  z-index: 2;
  background: linear-gradient(180deg, #fef3c7 0%, #ffffff 60%);
  box-shadow: 0 16rpx 48rpx rgba(245, 158, 11, 0.2);
}

.podium-item.second {
  background: linear-gradient(180deg, #f1f5f9 0%, #ffffff 60%);
}

.podium-item.third {
  background: linear-gradient(180deg, #ffedd5 0%, #ffffff 60%);
}

.podium-crown {
  font-size: 56rpx;
  margin-bottom: 4rpx;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.podium-rank {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.podium-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f43f5e, #ec4899);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
  box-shadow: 0 6rpx 20rpx rgba(244, 63, 94, 0.25);
}

.podium-avatar.gold {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  box-shadow: 0 6rpx 20rpx rgba(245, 158, 11, 0.3);
}

.podium-avatar.bronze {
  background: linear-gradient(135deg, #fb923c, #ea580c);
  box-shadow: 0 6rpx 20rpx rgba(249, 115, 22, 0.25);
}

.podium-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 6rpx;
  text-align: center;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.podium-days {
  font-size: 26rpx;
  color: #f43f5e;
  font-weight: 700;
}

.podium-item.first .podium-days {
  font-size: 28rpx;
  color: #d97706;
}

.ranking-list {
  padding: 0;
  overflow: hidden;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(244, 63, 94, 0.06);
}

.ranking-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f8fafc;
  transition: background 0.2s;
}

.ranking-item:last-child {
  border-bottom: none;
}

.ranking-item.is-me {
  background: linear-gradient(90deg, #fff1f2 0%, #ffffff 100%);
}

.rank-num {
  width: 48rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #cbd5e1;
}

.user-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f43f5e, #ec4899);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(244, 63, 94, 0.15);
}

.user-info {
  min-width: 0;
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.streak-tag {
  font-size: 22rpx;
  color: #f59e0b;
  font-weight: 500;
}

.user-days {
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #f43f5e, #ec4899);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.list-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin: 0 4rpx 20rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #f43f5e;
  border-radius: 4rpx;
}
