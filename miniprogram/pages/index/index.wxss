.container {
  padding-bottom: 160rpx;
}

.header {
  padding: 20rpx 0;
}

.greeting {
  color: #1e293b;
}

.event-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(244, 63, 94, 0.08);
  border-left: 8rpx solid #f43f5e;
}

.event-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.event-title {
  flex: 1;
  line-height: 1.4;
}

.event-meta {
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #64748b;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background: #fef2f2;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f43f5e, #ec4899);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.required-text {
  padding: 16rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  line-height: 1.5;
}

.event-actions {
  padding-top: 16rpx;
  border-top: 2rpx solid #f1f5f9;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  padding: 20rpx 0 calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: #94a3b8;
}

.nav-item.active {
  color: #f43f5e;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-text {
  font-size: 24rpx;
}
