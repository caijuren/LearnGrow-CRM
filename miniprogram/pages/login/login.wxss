.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f43f5e 0%, #fef2f2 50%);
  padding: 60rpx 48rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.login-header {
  text-align: center;
  margin-bottom: 60rpx;
  color: white;
}

.logo {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.login-card {
  background: white;
  border-radius: 28rpx;
  padding: 56rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(244, 63, 94, 0.1);
}

.welcome-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1e293b;
  text-align: center;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.btn-wechat {
  width: 100%;
  height: 96rpx;
  background: #07c160;
  color: white;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: none;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
}

.btn-wechat::after {
  border: none;
}

.wx-icon {
  font-size: 32rpx;
}

.btn-skip {
  width: 100%;
  height: 92rpx;
  background: #f8fafc;
  color: #64748b;
  border-radius: 46rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 32rpx;
}

.btn-skip::after {
  border: none;
}

.agreement {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  font-size: 24rpx;
  color: #64748b;
  padding: 0 24rpx;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 8rpx;
  margin-right: 16rpx;
  margin-top: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: white;
  line-height: 1;
  flex-shrink: 0;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #f43f5e;
  border-color: #f43f5e;
}

.agreement-text {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
  flex: 1;
  text-align: left;
}

.link {
  color: #f43f5e;
  font-weight: 500;
}

.footer-tip {
  margin-top: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.6;
}
