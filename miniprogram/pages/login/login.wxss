.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f43f5e 0%, #fef2f2 40%);
  padding: 80rpx 40rpx 40rpx;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
  color: white;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.title {
  color: white;
}

.subtitle {
  color: rgba(255, 255, 255, 0.9);
}

.login-form {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  color: #475569;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 96rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid #f1f5f9;
}

.input:focus {
  border-color: #f43f5e;
  background: white;
}

.agreement {
  text-align: center;
  font-size: 24rpx;
}

.tips {
  padding: 0 20rpx;
}

.tip-item {
  font-size: 26rpx;
  line-height: 1.6;
}

.text-sm {
  font-size: 24rpx;
}
