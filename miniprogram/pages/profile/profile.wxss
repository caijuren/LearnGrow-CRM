.container {
  padding-bottom: 180rpx;
}

.profile-guest {
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 60%, #f472b6 100%);
  border-radius: 32rpx;
  padding: 80rpx 48rpx 72rpx;
  margin-bottom: 32rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.profile-guest::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -80rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.profile-guest::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: 20%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.guest-avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 32rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.guest-avatar {
  font-size: 80rpx;
  position: relative;
  z-index: 1;
}

.guest-title {
  position: relative;
  z-index: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 16rpx;
}

.guest-desc {
  position: relative;
  z-index: 1;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.guest-login-btn {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 92rpx;
  padding: 0 64rpx;
  background: white;
  color: #f43f5e;
  border-radius: 46rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(244, 63, 94, 0.3);
}

.guest-login-btn::after {
  border: none;
}

.btn-arrow {
  font-size: 28rpx;
  font-weight: 500;
}

.profile-header {
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 60%, #f472b6 100%);
  border-radius: 32rpx;
  padding: 48rpx 36rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  position: relative;
  overflow: hidden;
}

.profile-header::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  font-size: 56rpx;
  background: rgba(255, 255, 255, 0.25);
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.profile-info {
  flex: 1;
  position: relative;
  z-index: 1;
}

.profile-name {
  color: white;
  font-size: 38rpx;
}

.profile-child {
  color: rgba(255, 255, 255, 0.9);
}

.edit-btn {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 12rpx 28rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: white;
  backdrop-filter: blur(10px);
}

.profile-edit-form {
  flex: 1;
  position: relative;
  z-index: 1;
}

.edit-form-item {
  margin-bottom: 20rpx;
}

.edit-input {
  width: 100%;
  height: 76rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.edit-btn-save {
  background: white !important;
  color: #f43f5e !important;
  font-size: 26rpx !important;
  padding: 14rpx 36rpx !important;
  border-radius: 24rpx !important;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1) !important;
  margin: 0;
  line-height: 1.4;
  font-weight: 600;
}

.edit-btn-save::after {
  border: none;
}

.edit-btn-cancel {
  background: rgba(255, 255, 255, 0.2) !important;
  color: white !important;
  font-size: 26rpx !important;
  padding: 14rpx 36rpx !important;
  border-radius: 24rpx !important;
  border: none !important;
  margin: 0;
  line-height: 1.4;
}

.edit-btn-cancel::after {
  border: none;
}

.stats-card {
  text-align: center;
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(244, 63, 94, 0.06);
}

.stats-card .stats-row {
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.stat-item .text-xl {
  font-size: 44rpx;
  font-weight: 700;
}

.stat-item:nth-child(1) .text-xl {
  background: linear-gradient(135deg, #f43f5e, #ec4899);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-item:nth-child(3) .text-xl {
  background: linear-gradient(135deg, #f59e0b, #f97316);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-item:nth-child(5) .text-xl {
  background: linear-gradient(135deg, #10b981, #059669);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #f1f5f9;
  border-radius: 2rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
}

.event-item {
  padding: 28rpx 0;
  border-bottom: 2rpx solid #f8fafc;
  transition: opacity 0.2s;
}

.event-item:last-child {
  border-bottom: none;
}

.event-item:active {
  opacity: 0.7;
}

.event-name {
  font-size: 30rpx;
  color: #1e293b;
}

.menu-card {
  padding: 0;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(244, 63, 94, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  transition: background 0.2s;
}

.menu-item:active {
  background: #fef2f2;
}

.menu-icon {
  font-size: 44rpx;
  width: 56rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
}

.menu-arrow {
  color: #cbd5e1;
  font-size: 32rpx;
  font-weight: 300;
}

.menu-divider {
  height: 2rpx;
  background: #f8fafc;
  margin: 0 32rpx 0 112rpx;
}

.logout-btn {
  width: 100%;
  margin-top: 28rpx;
  background: white;
  color: #f43f5e;
  border-radius: 24rpx;
  font-size: 30rpx;
  padding: 28rpx;
  border: none;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(244, 63, 94, 0.08);
  transition: all 0.2s;
}

.logout-btn:active {
  transform: scale(0.98);
  background: #fef2f2;
}

.logout-btn::after {
  border: none;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  display: flex;
  padding: 16rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
  border-top: 2rpx solid #f1f5f9;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  color: #94a3b8;
  transition: all 0.2s;
  padding: 8rpx 0;
}

.nav-item.active {
  color: #f43f5e;
}

.nav-item.active .nav-icon {
  transform: scale(1.1);
}

.nav-icon {
  font-size: 48rpx;
  transition: transform 0.2s;
}

.nav-text {
  font-size: 22rpx;
  font-weight: 500;
}

.section-title-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-title-bar text {
  margin-right: 12rpx;
}

.user-badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.user-badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: calc(20% - 13rpx);
  padding: 16rpx 8rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.1);
}

.user-badge-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.user-badge-name {
  font-size: 20rpx;
  color: #92400e;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
}
