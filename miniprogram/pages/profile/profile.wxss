.container {
  padding-bottom: 160rpx;
}

.profile-guest {
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 100%);
  border-radius: 32rpx;
  padding: 80rpx 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.guest-avatar {
  font-size: 100rpx;
}

.profile-header {
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 100%);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  font-size: 56rpx;
  background: rgba(255, 255, 255, 0.25);
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
}

.profile-name {
  color: white;
}

.edit-btn {
  display: inline-block;
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: white;
}

.profile-edit-form {
  flex: 1;
}

.edit-form-item {
  margin-bottom: 16rpx;
}

.edit-input {
  width: 100%;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.edit-btn-save {
  background: white !important;
  color: #f43f5e !important;
  font-size: 26rpx !important;
  padding: 12rpx 32rpx !important;
  border-radius: 20rpx !important;
  box-shadow: none !important;
  margin: 0;
  line-height: 1.4;
}

.edit-btn-save::after {
  border: none;
}

.edit-btn-cancel {
  background: rgba(255, 255, 255, 0.2) !important;
  color: white !important;
  font-size: 26rpx !important;
  padding: 12rpx 32rpx !important;
  border-radius: 20rpx !important;
  border: none !important;
  margin: 0;
  line-height: 1.4;
}

.edit-btn-cancel::after {
  border: none;
}

.stats-card {
  text-align: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-divider {
  width: 2rpx;
  background: #f1f5f9;
}

.stat-label {
  font-size: 24rpx;
}

.event-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
}

.event-item:last-child {
  border-bottom: none;
}

.event-name {
  font-size: 30rpx;
}

.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
}

.menu-icon {
  font-size: 40rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
}

.menu-divider {
  height: 2rpx;
  background: #f1f5f9;
  margin: 0 32rpx;
}

.logout-btn {
  width: 100%;
  margin-top: 24rpx;
  background: white;
  color: #f43f5e;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 28rpx;
  border: none;
}

.logout-btn::after {
  border: none;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  padding: 20rpx 0 calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: #94a3b8;
}

.nav-item.active {
  color: #f43f5e;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-text {
  font-size: 24rpx;
}
