.container {
  padding-bottom: 160rpx;
}

.page-header {
  padding: 20rpx 0 32rpx;
}

.checkin-card {
  border-left: 8rpx solid #f43f5e;
}

.stats-row {
  justify-content: space-between;
}

.stat-box {
  flex: 1;
  background: #fef2f2;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.mini-calendar {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.mini-day {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  background: #f1f5f9;
}

.mini-day.checked {
  background: linear-gradient(135deg, #f43f5e, #ec4899);
}

.records-scroll {
  white-space: nowrap;
}

.records-list {
  padding: 4rpx 0;
}

.record-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.record-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
}

.record-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #dcfce7;
  color: #16a34a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.record-date {
  font-size: 20rpx;
  color: #94a3b8;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  padding: 20rpx 0 calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: #94a3b8;
}

.nav-item.active {
  color: #f43f5e;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-text {
  font-size: 24rpx;
}
