page {
  background-color: #fef2f2;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #1e293b;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(244, 63, 94, 0.08);
}

.btn-primary {
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 100%);
  color: white;
  border-radius: 16rpx;
  padding: 28rpx 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(244, 63, 94, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #fef2f2;
  color: #f43f5e;
  border-radius: 16rpx;
  padding: 24rpx 36rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: 2rpx solid #fecdd3;
}

.btn-secondary::after {
  border: none;
}

.btn-small {
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
}

.text-primary {
  color: #f43f5e;
}

.text-secondary {
  color: #64748b;
}

.text-muted {
  color: #94a3b8;
}

.text-success {
  color: #10b981;
}

.text-warning {
  color: #f59e0b;
}

.flex {
  display: flex;
}

.flex-1 {
  flex: 1;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.gap-2 {
  gap: 16rpx;
}

.gap-3 {
  gap: 24rpx;
}

.gap-4 {
  gap: 32rpx;
}

.mt-2 {
  margin-top: 16rpx;
}

.mt-3 {
  margin-top: 24rpx;
}

.mt-4 {
  margin-top: 32rpx;
}

.mb-2 {
  margin-bottom: 16rpx;
}

.mb-3 {
  margin-bottom: 24rpx;
}

.mb-4 {
  margin-bottom: 32rpx;
}

.p-3 {
  padding: 24rpx;
}

.p-4 {
  padding: 32rpx;
}

.rounded-xl {
  border-radius: 20rpx;
}

.rounded-2xl {
  border-radius: 24rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.text-2xl {
  font-size: 40rpx;
}

.font-bold {
  font-weight: 700;
}

.font-semibold {
  font-weight: 600;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
  font-size: 48rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-success {
  background: #dcfce7;
  color: #16a34a;
}

.badge-warning {
  background: #fef3c7;
  color: #d97706;
}

.badge-rose {
  background: #ffe4e6;
  color: #e11d48;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #94a3b8;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
