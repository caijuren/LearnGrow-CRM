page {
  background: linear-gradient(180deg, #fff1f2 0%, #fdf2f8 50%, #fff7ed 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #1e293b;
  font-size: 28rpx;
  min-height: 100vh;
}

.container {
  padding: 32rpx 28rpx;
  min-height: 100vh;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(244, 63, 94, 0.06);
}

.btn-primary {
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 100%);
  color: white;
  border-radius: 24rpx;
  padding: 28rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(244, 63, 94, 0.25);
  transition: all 0.2s;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(244, 63, 94, 0.2);
}

.btn-secondary {
  background: #fff1f2;
  color: #f43f5e;
  border-radius: 24rpx;
  padding: 24rpx 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  background: #ffe4e6;
}

.btn-small {
  padding: 18rpx 32rpx;
  font-size: 26rpx;
  border-radius: 16rpx;
}

.btn-outline {
  background: white;
  color: #64748b;
  border-radius: 24rpx;
  padding: 24rpx 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid #e2e8f0;
}

.btn-outline::after {
  border: none;
}

.text-primary {
  color: #f43f5e;
}

.text-secondary {
  color: #64748b;
}

.text-muted {
  color: #94a3b8;
}

.text-success {
  color: #10b981;
}

.text-warning {
  color: #f59e0b;
}

.text-rose {
  color: #ec4899;
}

.flex {
  display: flex;
}

.flex-1 {
  flex: 1;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.gap-2 {
  gap: 16rpx;
}

.gap-3 {
  gap: 24rpx;
}

.gap-4 {
  gap: 32rpx;
}

.mt-1 {
  margin-top: 12rpx;
}

.mt-2 {
  margin-top: 16rpx;
}

.mt-3 {
  margin-top: 24rpx;
}

.mt-4 {
  margin-top: 32rpx;
}

.mb-2 {
  margin-bottom: 16rpx;
}

.mb-3 {
  margin-bottom: 24rpx;
}

.mb-4 {
  margin-bottom: 32rpx;
}

.p-3 {
  padding: 24rpx;
}

.p-4 {
  padding: 32rpx;
}

.rounded-xl {
  border-radius: 20rpx;
}

.rounded-2xl {
  border-radius: 24rpx;
}

.rounded-3xl {
  border-radius: 28rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.text-2xl {
  font-size: 40rpx;
}

.font-bold {
  font-weight: 700;
}

.font-semibold {
  font-weight: 600;
}

.font-medium {
  font-weight: 500;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(244, 63, 94, 0.2);
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
  font-size: 48rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-success {
  background: linear-gradient(135deg, #dcfce7, #bbf7d0);
  color: #15803d;
}

.badge-warning {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  color: #b45309;
}

.badge-rose {
  background: linear-gradient(135deg, #ffe4e6, #fbcfe8);
  color: #be123c;
}

.badge-primary {
  background: linear-gradient(135deg, #ffe4e6, #fce7f3);
  color: #db2777;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #94a3b8;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 20rpx;
}

.divider {
  height: 2rpx;
  background: #f1f5f9;
  margin: 24rpx 0;
}
